# ============================================================
# .env.example — Template de variáveis de ambiente
# ============================================================
# Copie este arquivo para .env (que é ignorado pelo Git) e
# preencha os valores. NUNCA commite o arquivo .env real.
#
#   cp .env.example .env
# ============================================================

# --- Parâmetros de mercado (atualizar periodicamente via Damodaran) ---
# ERP dos EUA (Equity Risk Premium) — fonte: Damodaran, atualizado em jan de cada ano
ERP_EUA=0.045

# Country Risk Premium do Brasil — fonte: Damodaran / CDS 5 anos
CRP_BRASIL=0.028

# CPI de longo prazo dos EUA (para conversão Ke USD->BRL)
CPI_EUA=0.025

# Alíquota de IR/CSLL padrão para empresas gerais
ALIQUOTA_PADRAO=0.34

# Alíquota do RET para construtoras (sobre a Receita Bruta)
ALIQUOTA_RET=0.04

# --- Configuração de execução ---
# Nível de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Número de anos históricos a coletar da CVM (5 a 7)
ANOS_HISTORICOS=7

# Horizonte de projeção explícita (fixo em 8 pelo design do projeto)
HORIZONTE_PROJECAO=8

# --- Caminhos (opcionais; usam defaults se não definidos) ---
# DATA_DIR=data
# OUTPUTS_DIR=outputs
